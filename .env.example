# Required API keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here
FIRECRAWL_API_KEY=fc-your-key-here
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_OWNER_ID=your-telegram-user-id

# Optional: PostgreSQL connection string for the wrapped-repos registry.
# When set, previously-wrapped repos are cached so they don't get rebuilt
# from scratch every time. If unset, everything still works — without the
# caching speed benefit.
# Format: postgres://user:password@host:port/database
# Example (local pgAdmin4/default Postgres install on Windows):
#   postgres://postgres:mysecretpassword@localhost:5432/openarch
DATABASE_URL=postgres://postgres:your-password@localhost:5432/openarch
